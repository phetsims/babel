  "unitsInfo.content": {
    "value": "<b>تێبینیی ١:</b> یەکەیەکی گەردوونناسی (AU) نزیکەی ١٥٠ ملیۆن کیلۆمەترە. ئەمە تێکڕای دووریی نێوان خۆر و زەوییە.",
    "history": [
      {
        "userId": 11503104,
        "timestamp": 1783856040131,
        "oldValue": "",
        "newValue": "<b>تێبینیی ١:</b> یەکەیەکی گەردوونناسی (AU) نزیکەی ١٥٠ ملیۆن کیلۆمەترە. ئەمە تێکڕای دووریی نێوان خۆر و زەوییە."
      }
    ]
  },
  "unitsInfo.content2": {
    "value": "<b>تێبینیی ٢:</b> بەهاکانی بارستە لەم هاوشێوەسازییەدا لە نێوان ١ بارستەی هورمز (موشتەری) تاوەکو ١.٥ بارستەی خۆردایە. هەموو تەنە گەردوونییەکان لەژێر کێڵگەیەکی کێشکردنی بەهێزدا ڕەفتارێکی هاوشێوە نیشان دەدەن، لە نێوانیاندا هەسارە بچووکترەکان، ئەستێرە کلکدارەکان و گەڕەستێرۆچکەکان.",
    "history": [
      {
        "userId": 11503104,
        "timestamp": 1783856040131,
        "oldValue": "",
        "newValue": "<b>تێبینیی ٢:</b> بەهاکانی بارستە لەم هاوشێوەسازییەدا لە نێوان ١ بارستەی هورمز (موشتەری) تاوەکو ١.٥ بارستەی خۆردایە. هەموو تەنە گەردوونییەکان لەژێر کێڵگەیەکی کێشکردنی بەهێزدا ڕەفتارێکی هاوشێوە نیشان دەدەن، لە نێوانیاندا هەسارە بچووکترەکان، ئەستێرە کلکدارەکان و گەڕەستێرۆچکەکان."
      }
    ]
  },
  "unitsInfo.content3": {
    "value": "<b>تێبینیی ٣:</b> بەهۆی مەودای گەورەی بەهاکان لە هاوشێوەسازییەکەدا، ڕەنگە ئاڕاستەبڕەکانی هێزی کێشکردن هەندێک جار زۆر بچووک یان زۆر گەورە بن بۆ پیشاندان. دەکرێت ئاڕاستەبڕەکانی هێزی کێشکردن قەبارەیان ڕێکبخرێتەوە لەڕێگەی کۆنترۆڵکردنی نزیککردنەوەوە (زووم).",
    "history": [
      {
        "userId": 11503104,
        "timestamp": 1783856040131,
        "oldValue": "",
        "newValue": "<b>تێبینیی ٣:</b> بەهۆی مەودای گەورەی بەهاکان لە هاوشێوەسازییەکەدا، ڕەنگە ئاڕاستەبڕەکانی هێزی کێشکردن هەندێک جار زۆر بچووک یان زۆر گەورە بن بۆ پیشاندان. دەکرێت ئاڕاستەبڕەکانی هێزی کێشکردن قەبارەیان ڕێکبخرێتەوە لەڕێگەی کۆنترۆڵکردنی نزیککردنەوەوە (زووم)."
      }
    ]
  },
