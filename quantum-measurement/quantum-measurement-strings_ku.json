  "averagePolarizationDialog.explanatoryParagraph": {
    "value": "هاوکێشەکە بەهایەک لە نێوان ۱+ و ۱- بەدەستەوە دەدات. ئەم بەهایە نوێنەرایەتی تێکڕای کێشراوی جەمسەرگیریی فۆتۆنە دۆزراوەکان دەکات ئەگەر هەر دۆزینەوەیەکی جەمسەرگیریی ستوونی بە بەهای ۱+ دابنرێت و هەر دۆزینەوەیەکی جەمسەرگیریی ئاسۆیی بە بەهای ۱- دابنرێت. هەروەها دەکرێت ئەم بەهایە ببەسترێتەوە بە پیشاندانی ئاڕاستەبڕێک (ڤێکتەرێک) کە لە نێوان بەهای ۱+ و ۱- دایە.",
    "history": [
      {
        "userId": 11503104,
        "timestamp": 1783268516877,
        "oldValue": "",
        "newValue": "هاوکێشەکە بەهایەک لە نێوان ۱+ و ۱- بەدەستەوە دەدات. ئەم بەهایە نوێنەرایەتی تێکڕای کێشراوی جەمسەرگیریی فۆتۆنە دۆزراوەکان دەکات ئەگەر هەر دۆزینەوەیەکی جەمسەرگیریی ستوونی بە بەهای ۱+ دابنرێت و هەر دۆزینەوەیەکی جەمسەرگیریی ئاسۆیی بە بەهای ۱- دابنرێت. هەروەها دەکرێت ئەم بەهایە ببەسترێتەوە بە پیشاندانی ئاڕاستەبڕێک (ڤێکتەرێک) کە لە نێوان بەهای ۱+ و ۱- دایە."
      }
    ]
  },
